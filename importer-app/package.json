{
  "name": "nxt5-importer",
  "version": "0.1.0",
  "private": true,
  "description": "NXT5 local match importer",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "electron": "^31.7.7"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "app.nxt5.importer",
    "productName": "NXT5 Importer",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "NXT5-Importer-${version}-${target}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
